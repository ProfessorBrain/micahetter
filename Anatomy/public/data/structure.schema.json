{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://critical-structures.local/schemas/structure.schema.json",
  "title": "Critical Structures anatomy record",
  "type": "object",
  "required": ["id", "name", "aliases", "zone", "subzones", "system", "pieceType", "pieceAsset", "distractorTags", "clues", "requiredZoomPath", "finalBoard", "target", "minimumOverlap", "idealRotation", "rotationTolerance", "nearMissZones", "feedback"],
  "properties": {
    "id": {"type":"string", "pattern":"^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name": {"type":"string", "minLength":2},
    "aliases": {"type":"array", "items":{"type":"string"}},
    "zone": {"enum":["face","arm","leg","neck-back","neuro","thorax","abdomen-pelvis"]},
    "subzones": {"type":"array", "minItems":1, "items":{"type":"string"}},
    "system": {"type":"string"},
    "pieceType": {"enum":["muscle","organ","pathway"]},
    "pieceAsset": {"type":"string", "pattern":"^/assets/.+\\.svg$"},
    "distractorTags": {"type":"array", "minItems":2, "items":{"type":"string"}},
    "clues": {"type":"object", "minProperties":4, "propertyNames":{"enum":["name","function","dysfunction","origin","insertion","innervation","bloodSupply","histology","substance","anatomicalRelationship","development","imaging","clinical","surfaceLandmark","pathway"]}, "additionalProperties":{"type":"string","minLength":12}},
    "requiredZoomPath": {"type":"array", "minItems":2, "items":{"type":"string"}},
    "finalBoard": {"type":"string"},
    "target": {"type":"object", "required":["x","y","radius"], "properties":{"x":{"type":"number","minimum":0,"maximum":100},"y":{"type":"number","minimum":0,"maximum":100},"radius":{"type":"number","exclusiveMinimum":0,"maximum":50}}, "additionalProperties":false},
    "minimumOverlap": {"type":"number","minimum":0,"maximum":1},
    "idealRotation": {"type":"number","minimum":-180,"maximum":180},
    "rotationTolerance": {"type":"number","minimum":0,"maximum":180},
    "nearMissZones": {"type":"array", "items":{"$ref":"#/$defs/circle"}},
    "attachmentPoints": {"type":"array", "items":{"$ref":"#/$defs/point"}},
    "pathEndpoints": {"type":"array", "items":{"$ref":"#/$defs/point"}},
    "feedback": {"type":"object", "required":["correct","review"], "properties":{"correct":{"type":"string"},"review":{"type":"string"}}, "additionalProperties":false}
  },
  "$defs": {
    "point": {"type":"object", "required":["x","y"], "properties":{"x":{"type":"number","minimum":0,"maximum":100},"y":{"type":"number","minimum":0,"maximum":100},"label":{"type":"string"}}},
    "circle": {"type":"object", "required":["x","y","radius"], "properties":{"x":{"type":"number","minimum":0,"maximum":100},"y":{"type":"number","minimum":0,"maximum":100},"radius":{"type":"number","exclusiveMinimum":0}}}
  },
  "additionalProperties": false
}
